{
  "name": "bemind-search-mcp",
  "version": "2.0.0",
  "description": "BeMind Search MCP Server — Azure AI Search, SAP, Microsoft Graph, Office document tools",
  "module": "src/server.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "bun run src/server.ts",
    "build": "bun build --compile src/server.ts --outfile dist/bemind-search-mcp",
    "build:all": "bash scripts/build-all.sh",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/pdfkit": "^0.17.5"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "docx": "^9.6.0",
    "exceljs": "^4.4.0",
    "pdfkit": "^0.17.2",
    "pptxgenjs": "^4.0.1",
    "zod": "^4.3.6"
  }
}
